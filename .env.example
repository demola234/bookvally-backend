# Copy to .env and fill in values
# Never commit .env

# ── Server ──────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgres://bookvally:bookvally@localhost:5432/bookvally
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=bookvally-api

# ── Auth / JWT ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=2592000

# ── OAuth providers ─────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY_PATH=

# ── OpenTelemetry ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=bookvally-api
OTEL_SERVICE_VERSION=0.1.0

# ── Storage ──────────────────────────────────────────────────
APP__STORAGE__PUBLIC_URL=https://your-cdn-domain.r2.dev
APP__STORAGE__SECRET_ACCESS_KEY=...
APP__STORAGE__ACCESS_KEY_ID=...
APP__STORAGE__REGION=auto
APP__STORAGE__BUCKET=book-vally
APP__STORAGE__ENDPOINT=https://<account_id>.r2.cloudflarestorage.com